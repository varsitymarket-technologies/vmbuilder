                        "backgroundColor": "#111827",
                        "textColor": "#9ca3af",
                        "links": [
                            {"label": "Privacy Policy", "url": "#"},
                            {"label": "Terms of Service", "url": "#"}
                        ],
                        "socialLinks": [
                            {"platform": "facebook", "url": "#"},
                            {"platform": "twitter", "url": "#"},
                            {"platform": "linkedin", "url": "#"}
                        ]
                    }
                }
