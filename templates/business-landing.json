            },
            "components": [
                {
                    "id": "nav1",
                    "type": "navbar",
                    "props": {
                        "logo": "",
                        "logoText": "BusinessCo",
                        "backgroundColor": "#ffffff",
                        "textColor": "#111827",
                        "sticky": true
                    }
                },
                {
                    "id": "hero1",
                    "type": "hero",
                    "props": {
                        "heading": "Grow Your Business With Us",
